# =============================================================================
# [NOME_APP] — Environment variables template
# Copia in .env.local e popola con i valori reali. NON committare .env.local.
# Variabili NEXT_PUBLIC_* sono esposte al browser. Tutte le altre sono server-only.
# =============================================================================

# --- App ---
# URL completo dell'app, no trailing slash. http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
# Project ref dalla dashboard (sottodominio del project URL).
SUPABASE_PROJECT_REF=
# Project URL pubblica (https://<ref>.supabase.co).
NEXT_PUBLIC_SUPABASE_URL=
# Anon/publishable key (sicura da esporre al browser, soggetta a RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (BYPASSA RLS). Solo server-side. Mai esporre al browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cifratura at-rest dei token API esterni (Pyva, Fatture in Cloud) ---
# Genera con: openssl rand -base64 32
# Cambiare questa chiave in produzione invalida i token cifrati esistenti.
ENCRYPTION_KEY=

# --- Email transazionali (Resend) — Batch C in poi ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="[NOME_APP] <noreply@example.com>"

# --- Stripe — Batch E in poi ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_YEARLY=

# --- Pyva — Batch D in poi ---
# Mock mode: il client logga le call e ritorna risposte fake. Default true in dev.
PYVA_MOCK=true
PYVA_API_BASE_URL=
PYVA_WEBHOOK_SECRET=

# --- Feature flags ---
# Quando true, mostra il pulsante Google sui form auth. Richiede credenziali OAuth
# configurate in Supabase Auth dashboard. Default OFF finché non setup completo.
NEXT_PUBLIC_FEATURE_GOOGLE_AUTH=false

# --- Sentry — Batch F in poi ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
