# Auto-detect text files and normalize to LF in repo
* text=auto eol=lf

# Source files
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.pdf binary
*.zip binary
